server {
    listen 8081;
    server_name localhost;

    root /var/www/login-sad-php/public;
    index index.php;

    # CORS preflight handled by PHP; just pass through
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include        fastcgi_params;
        fastcgi_pass   unix:/run/php/php8.2-fpm.sock;  # adjust PHP version
        fastcgi_param  SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }

    # Block access to everything outside /public
    location ~* \.(env|json|md|txt|xml|yml)$ {
        deny all;
    }
}
