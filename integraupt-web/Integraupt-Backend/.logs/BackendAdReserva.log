            ? IS NULL 
            OR e.Tipo = ?
        )   
        AND (
            ? IS NULL 
            OR fac.IdFacultad = ?
        )   
        AND (
            ? IS NULL 
            OR esc.IdEscuela = ?
        )   
        AND (
            ? IS NULL 
            OR r.fechaReserva = ?
        )   
        AND (
            ? IS NULL 
            OR         LOWER(e.Nombre) LIKE LOWER(CONCAT('%', ?, '%')) 
            OR         LOWER(e.Codigo) LIKE LOWER(CONCAT('%', ?, '%')) 
            OR         LOWER((SELECT
                CONCAT(u.Nombre, ' ', u.Apellido) 
            FROM
                usuario u 
            WHERE
                u.IdUsuario = r.usuario)) LIKE LOWER(CONCAT('%', ?, '%'))   
        ) 
    GROUP BY
        r.Estado 
